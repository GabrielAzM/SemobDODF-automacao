SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_de_app_do_gmail
MAIL_FROM=seu_email@gmail.com
MAIL_TO=destinatario@exemplo.com

# Use smtp no Render ou gmail_api quando SMTP estiver bloqueado localmente.
EMAIL_DELIVERY=smtp
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

ATTACH_PDF=true
MAX_ATTACHMENT_MB=20
SEND_EMPTY_REPORT=true
DODF_BASE_URL=https://dodf.df.gov.br
TIMEZONE=America/Sao_Paulo
HTTP_TIMEOUT_SECONDS=30
MAX_RETRIES=6
RETRY_DELAY_SECONDS=300

# true = varre o diario inteiro e pega mencoes textuais, inclusive decretos de nomeacao/exoneracao.
SCAN_FULL_DIARIO=true

# Separe termos extras por ponto e virgula ou quebra de linha.
DODF_KEYWORDS=

# true = em materias muito amplas, envia apenas os blocos que mencionam os termos.
RELEVANT_SNIPPETS_ONLY=true
RELEVANT_CONTEXT_LINES=0

# Evita envio duplicado quando a tentativa reserva das 06:40 roda depois da principal.
SENT_STATE_FILE=state/sent_reports.json
SKIP_ALREADY_SENT=true
